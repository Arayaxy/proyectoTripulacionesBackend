{
  "info": {
    "name": "Proyecto Tripulaciones API",
    "description": "Colección para probar los endpoints en local.\n\n## Autenticación\n1. Usa el endpoint **Login** con un token de Firebase en el header `Authorization: Bearer <firebase_token>`.\n2. El servidor responde con una cookie httpOnly con el JWT.\n3. Copia el valor de la cookie `token` de los response headers (Set-Cookie).\n4. Pégalo como valor de la variable `jwt_token` en la colección (Edit → Variables).\n5. El resto de endpoints lo usarán automáticamente en `Authorization: Bearer {{jwt_token}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000/api/v1" },
    { "key": "jwt_token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        { "name": "GET Health Check", "request": { "method": "GET", "url": "{{base_url}}/health" } },
        { "name": "GET Debug Force Error (solo dev)", "request": { "method": "GET", "url": "{{base_url}}/debug/force-error" } }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer <firebase_token>" }],
            "url": "{{base_url}}/auth/login"
          }
        },
        { "name": "GET Verify Session", "request": { "method": "GET", "url": "{{base_url}}/auth/verify" } },
        { "name": "POST Logout", "request": { "method": "POST", "url": "{{base_url}}/auth/logout" } }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "POST subir archivo",
          "request": {
            "method": "POST",
            "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "" }] },
            "url": "{{base_url}}/upload"
          }
        }
      ]
    },
    {
      "name": "Eventos",
      "item": [
        { "name": "GET listar eventos", "request": { "method": "GET", "url": "{{base_url}}/eventos" } },
        { "name": "GET filtrar eventos", "request": { "method": "GET", "url": "{{base_url}}/eventos?ciudad=Bilbao&tipoEvento=Congreso" } },
        { "name": "GET buscar evento por ID", "request": { "method": "GET", "url": "{{base_url}}/eventos/bdfe40ca-70e8-4fe6-8907-df4a5a7bd3e6" } },
        {
          "name": "POST crear evento",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombreEvento\": \"Evento de prueba\",\n  \"ciudad\": \"Bilbao\",\n  \"lugarConfirmado\": \"Palacio Europa\",\n  \"fechaInicio\": \"2026-07-15\",\n  \"fechaFin\": \"2026-07-17\",\n  \"numeroPersonas\": 200,\n  \"tipoEvento\": \"Congreso\",\n  \"nota\": \"\",\n  \"idCliente\": \"uuid-del-cliente\",\n  \"idEstado\": \"uuid-del-estado\"\n}" },
            "url": "{{base_url}}/eventos"
          }
        },
        {
          "name": "PATCH actualizar evento",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombreEvento\": \"Evento actualizado\",\n  \"numeroPersonas\": 250\n}" },
            "url": "{{base_url}}/eventos/bdfe40ca-70e8-4fe6-8907-df4a5a7bd3e6"
          }
        },
        { "name": "DELETE eliminar evento", "request": { "method": "DELETE", "url": "{{base_url}}/eventos/bdfe40ca-70e8-4fe6-8907-df4a5a7bd3e6" } }
      ]
