model Presupuesto {
  id                  String   @id @default(uuid(7)) @db.Uuid
  estadoPresupuesto   Boolean  @map("estado_presupuesto")
  total               Float
  fecha               DateTime @db.Timestamptz(0)
  notaUbicacion       String?  @map("nota_ubicacion")
  precioUbicacion     Float    @map("precio_ubicacion")
  catering            Boolean
  notaCatering        String?  @map("nota_catering")
  precioCatering      Float    @map("precio_catering")
  audiovisuales       Boolean
  notaAudiovisuales   String?  @map("nota_audiovisuales")
  precioAudiovisuales Float    @map("precio_audiovisuales")
  otros               Boolean
  notaOtros           String?  @map("nota_otros")
  precioOtros         Float    @map("precio_otros")
  observaciones       String?
  evento              Evento?

  @@map("presupuestos")
}
