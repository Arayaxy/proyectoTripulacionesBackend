model Presupuesto {
  id_presupuesto       String  @id @default(uuid(7)) @db.Uuid
  estado_prespuesto    Boolean
  total                Int
  fecha                Int
  nota_ubicacion       String
  precio_ubicacion     Int
  nota_catering        String
  precio_catering      Int
  nota_audiovisuales   String
  precio_audiovisuales Int
  nota_otros           String
  precio_otros         Int
  catering             Boolean
  audiovisuales        Boolean
  otros                Boolean
  observaciones        String
  eventoId             String  @db.Uuid
  evento               Evento  @relation(fields: [eventoId], references: [id_evento]) // Enlace de clave foránea

  @@map("presupuestos")
}
