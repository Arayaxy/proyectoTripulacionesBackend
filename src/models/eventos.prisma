model Evento {
  id              String       @id @default(uuid(7)) @db.Uuid
  nombreEvento    String       @map("nombre_evento")
  ciudad          String
  lugarConfirmado String       @map("lugar_confirmado")
  fechaInicio     DateTime     @map("fecha_inicio")
  fechaFin        DateTime     @map("fecha_fin")
  numeroPersonas  Int          @map("numero_personas")
  tipoEvento      String       @map("tipo_evento")
  nota            String?
  idPresupuesto   String?      @unique @map("id_presupuesto") @db.Uuid
  presupuesto     Presupuesto? @relation(fields: [idPresupuesto], references: [id]) // Enlace de clave foránea
  idCliente       String       @map("id_cliente") @db.Uuid
  cliente         Cliente      @relation(fields: [idCliente], references: [id]) // Enlace de clave foránea
  idEstado        String       @map("id_estado") @db.Uuid
  estado          Estado       @relation(fields: [idEstado], references: [id]) // Enlace de clave foránea
  idSala          String?      @map("id_sala") @db.Uuid
  sala            Sala?        @relation(fields: [idSala], references: [id]) // Enlace de clave foránea
  idPonencia      String?      @map("id_ponencia") @db.Uuid
  ponencia        Ponencia?    @relation(fields: [idPonencia], references: [id]) // Enlace de clave foránea

  @@map("eventos")
}
