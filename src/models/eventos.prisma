model Evento {
  id_evento       String         @id @default(uuid(7)) @db.Uuid
  nombreEvento    String         @map("nombre_evento")
  ciudad          String
  lugarConfirmado String         @map("lugar_confirmado")
  fechaInicio     DateTime       @map("fecha_inicio")
  fechaFin        DateTime       @map("fecha_fin")
  numeroPersonas  Int            @map("numero_personas")
  tipoEvento      String         @map("tipo_evento")
  nota            String
  presupuestoId   String?        @unique @map("id_presupuesto") @db.Uuid
  presupuesto     Presupuesto?   @relation(fields: [presupuestoId], references: [id_presupuesto]) // Enlace de clave foránea
  clienteId       String         @map("id_cliente") @db.Uuid
  cliente         Cliente        @relation(fields: [clienteId], references: [id_cliente]) // Enlace de clave foránea
  estadoId        String         @map("id_estado") @db.Uuid
  estado          Estado         @relation(fields: [estadoId], references: [id_estado]) // Enlace de clave foránea
  salaId          String         @map("id_sala") @db.Uuid
  sala            Sala           @relation(fields: [salaId], references: [id_sala]) // Enlace de clave foránea
  eventoPonenteId String         @map("id_evento_ponente") @db.Uuid
  eventoPonente   EventosPonente @relation(fields: [eventoPonenteId], references: [id_evento_ponente]) // Enlace de clave foránea

  @@map("eventos")
}
